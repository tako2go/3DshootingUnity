--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: b810f88b6d89e1a45941e034d74d6b0f, type: 3}
  m_Name: Dialogue_Data_Boss
  m_EditorClassIdentifier: 
  Dialogue_Group:
    DialogueSequence:
    - lines:
      - speaker: 2
        expression: 3
        text: "\u3061\u3087\u3063\u3068\u305D\u3053\u306E\u3042\u306A\u305F!\u4F55\u3057\u3066\u308B\u306E\u3088\uFF01"
      - speaker: 0
        expression: 0
        text: "\u3048\u3001\u3060\u3001\u8AB0\uFF1F"
      - speaker: 2
        expression: 3
        text: "\u79C1\u306F\u30D5\u30A3\u30E9\u30FC\u30CD"
      - speaker: 2
        expression: 3
        text: "\u3042\u306A\u305F\u304C\u305F\u304F\u3055\u3093\u3044\u3058\u3081\u305F\u3053\u306E\u5B50\u305F\u3061\u306E\u304A\u53CB\u9054\u3088\uFF01"
      - speaker: 1
        expression: 0
        text: "\u3042\u306A\u305F\u304C\u4ECA\u56DE\u306E\u9A12\u52D5\u306E\u9996\u8B00\u8005\u3067\u3059\u306D"
      - speaker: 1
        expression: 0
        text: "\u3053\u3061\u3089\u3068\u3057\u3066\u306F\u8FF7\u60D1\u306A\u306E\u3067\u3001\u529B\u3065\u304F\u3067\u6B62\u3081\u3055\u305B\u3066\u3082\u3089\u3044\u307E\u3059\u3002"
      - speaker: 0
        expression: 4
        text: "\u3048\uFF1F"
      - speaker: 2
        expression: 3
        text: "\u3075\u30FC\u3093\u3002\u3053\u306E\u5B50\u305F\u3061\u3092\u3044\u3058\u3081\u308B\u3063\u3066\u3044\u3046\u306A\u3089\u3001\u79C1\u304C\u8A31\u3055\u306A\u3044\u3093\u3060\u304B\u3089\uFF01\uFF01"
      - speaker: 0
        expression: 4
        text: "\u50D5\u306F\u305D\u3093\u306A\u3064\u3082\u308A\u306A\u3044\u3093\u3067\u3059\u3051\u3069\uFF01\uFF1F"
    - lines:
      - speaker: 2
        expression: 0
        text: "\u3075\u30FC\u3093\u3002\u5C11\u3057\u306F\u3084\u308B\u3058\u3083\u306A\u3044\u3002"
      - speaker: 0
        expression: 0
        text: "\u3042\u3001\u3058\u3083\u3042\u3082\u3046\u3053\u3093\u306A\u3053\u3068\u306F\u7D42\u308F\u308A\u306B..."
      - speaker: 2
        expression: 3
        text: "\u305D\u3093\u306A\u308F\u3051\u306A\u3044\u3058\u3083\u306A\u3044\uFF01\uFF01"
      - speaker: 2
        expression: 3
        text: "\u3042\u306A\u305F\u306E\u3053\u3068\u306F\u7D76\u5BFE\u306B\u5012\u3059\u3093\u3060\u304B\u3089\uFF01\uFF01"
    - lines:
      - speaker: 2
        expression: 4
        text: "(\u306A\u3001\u306A\u306B\u3088\u3053\u3044\u3064\u3002\u5F37\u3059\u304E\u308B\u308F)"
      - speaker: 2
        expression: 4
        text: "(\u3053\u306E\u307E\u307E\u3058\u3083\u79C1\u3001\u672C\u5F53\u306B...)"
      - speaker: 2
        expression: 4
        text: "(\u3053\u306E\u307E\u307E\u3058\u3083\u79C1\u3001\u672C\u5F53\u306B...)"
      - speaker: 1
        expression: 0
        text: "(\u305D\u308C\u306B\u3057\u3066\u3082\u3001\u307E\u3055\u304B\u4E3B\u6BBF\u304C\u3053\u3053\u307E\u3067\u5F37\u3044\u306A\u3093\u3066...)"
      - speaker: 1
        expression: 0
        text: "(\u6700\u521D\u898B\u305F\u3068\u304D\u306F\u306A\u3093\u3067\u3053\u3093\u306A\u5B50\u4F9B\u304C\u3068\u601D\u3044\u307E\u3057\u305F\u304C...)"
      - speaker: 1
        expression: 0
        text: "(\u307E\u3055\u304B\u4E3B\u6BBF\u306F...\u307E\u4ECA\u306F\u3044\u3044\u3067\u3057\u3087\u3046)"
      - speaker: 2
        expression: 0
        text: "\u3072\u3063\uFF01\uFF1F\u3042\u306E\u3001\u5C11\u3057\u4F11\u6226\u3068\u304B\u3063\u3066..."
      - speaker: 1
        expression: 0
        text: "\u4E3B\u6BBF\uFF01\u7573\u307F\u304B\u3051\u3066\u304F\u3060\u3055\u3044\uFF01"
      - speaker: 0
        expression: 0
        text: "\u672C\u5F53\u306F\u3044\u3084\u3060\u3051\u3069...\u50D5\u9811\u5F35\u308B\u3088\uFF01\uFF01"
      - speaker: 2
        expression: 0
        text: "\u4EBA\u306E\u8A71\u3092\u805E\u304D\u306A\u3055\u3044\uFF5E\uFF5E\uFF5E\uFF01\uFF01\uFF01"
    - lines:
      - speaker: 0
        expression: 0
        text: "\u306F\u3041\u3001\u306F\u3041...\u52DD\u3063\u305F\u306E\u304B\u306A\uFF1F"
      - speaker: 1
        expression: 0
        text: "\u306F\u3044\u3002\u4E3B\u6BBF"
      - speaker: 1
        expression: 0
        text: "\u3055\u3042\u3001\u3068\u3069\u3081\u3092\u523A\u3057\u3066\u304F\u3060\u3055\u3044\u3002"
      - speaker: 0
        expression: 0
        text: "\u305D\u3046\u3044\u3046\u7269\u9A12\u306A\u306E\u306F\u6016\u3044\u3093\u3060\u3051\u3069..."
      - speaker: 2
        expression: 4
        text: "\u3048\u3063...\u79C1...\u6B7B\u306C\u306E\uFF1F"
      - speaker: 2
        expression: 0
        text: "\u6016\u3044...\u6016\u3044\u3088..."
      - speaker: 0
        expression: 0
        text: "\u3058\u3083\u3042\u3001\u3059\u307F\u307E\u305B\u3093\u304C..."
      - speaker: 2
        expression: 4
        text: "\u3072\u3045\u3063!"
      - speaker: 0
        expression: 0
        text: "\u3063\u3066"
      - speaker: 0
        expression: 2
        text: "\u53EF\u611B\u3044\uFF5E\uFF5E\uFF5E\uFF01\uFF01\uFF01"
      - speaker: 2
        expression: 0
        text: "\u3048\uFF1F"
      - speaker: 0
        expression: 2
        text: "\u306A\u306B\u3053\u306E\u5973\u6027\uFF01\uFF01\u3055\u3063\u304D\u306F\u9060\u304F\u3066\u308F\u304B\u3089\u306A\u304B\u3063\u305F\u3051\u3069\u3059\u3054\u304F\u304B\u308F\u3044\u3044\uFF01\uFF01"
      - speaker: 1
        expression: 0
        text: "\u3042\u3001\u4E3B\u6BBF\uFF01\uFF1F\u4F55\u3092\u8A00\u3063\u3066\u3044\u308B\u3093\u3067\u3059\u304B\uFF01\uFF1F"
      - speaker: 0
        expression: 0
        text: "\u50D5\u3001\u3053\u3093\u306A\u304B\u308F\u3044\u3044\u5B50\u306F\u6BBA\u305B\u306A\u3044\u3088..."
      - speaker: 2
        expression: 4
        text: "(\u306A\u3001\u4F55\u8A00\u3063\u3066\u308B\u306E\u304B\u3057\u3089\u3053\u306E\u4EBA\u3002)"
      - speaker: 2
        expression: 4
        text: "(\u3067\u3082\u3001\u52A9\u304B\u3063\u305F\u306E\u304B\u3057\u3089)"
      - speaker: 0
        expression: 0
        text: "\u3042\u3001\u3042\u306E\u3002\u3088\u304B\u3063\u305F\u3089\u50D5\u306E\u304A\u9858\u3044\u3092\u805E\u3044\u3066\u304F\u308C\u307E\u305B\u3093\u304B\uFF1F"
      - speaker: 1
        expression: 0
        text: "\u3061\u3087\uFF01\u4F55\u8A00\u3063\u3066\u308B\u3093\u3067\u3059\u304B\uFF01\u901F\u304F\u3068\u3069\u3081\u3092\u523A\u3057\u3066\u304F\u3060\u3055\u3044\uFF01"
      - speaker: 0
        expression: 0
        text: "\u9759\u304B\u306B\u3057\u3066"
      - speaker: 3
        expression: 0
        text: "\u3042\u306A\u305F\u306F\u30C0\u30EA\u30A2\u306E\u53E3\u3092\u6291\u3048\u305F"
      - speaker: 2
        expression: 4
        text: "\u306F\u3044\u3002\u308F\u304B\u308A\u307E\u3057\u305F\u3002"
      - speaker: 2
        expression: 4
        text: "(\u305B\u3063\u304B\u304F\u751F\u304D\u6B8B\u308C\u305D\u3046\u3060\u3082\u306E\u3002\u6A5F\u5ACC\u3092\u640D\u306D\u306A\u3044\u3088\u3046\u306B\u3057\u306A\u3044\u3068\u3002)"
      - speaker: 0
        expression: 0
        text: "\u3048\u3063\u3068..."
      - speaker: 0
        expression: 0
        text: "\u50D5\u3068\u7D50\u5A5A\u3057\u3066\u304F\u3060\u3055\u3044\uFF01\uFF01"
      - speaker: 1
        expression: 0
        text: "\u306F\u3044\u3002\u308F\u304B\u308A\u307E\u3057\u305F\u3002"
      - speaker: 3
        expression: 0
        text: ...
      - speaker: 1
        expression: 0
        text: "\u3063\u3066\u3002"
      - speaker: 1
        expression: 0
        text: "\u3048\u3048\u3048\u3048\u3048\u3048\u3048\u3048\u3048\u3048\u3048\u3048\u3048\u3048\u3048\u3048\u3048\u3048\u3048\u3048\u3048\u3048\u3048\u3048\u3048\u3048\u3048\u3048\u3048\u3048\u3048\u3048\u3048\u3048\u3048\u3048\u3048\u3048\u3048\u3048\u3048\u3048\u3048\u3048\u3048\u3048\u3048\u3048\u3048\u3048\u3048\u3048\u3048\u3048\u3048\u3048\u3048\u3048\u3048\u3048\u3048\u3048\u3048\u3048\u3048\u3048\u3048\uFF01\uFF1F"
  sprite_right: 2
  sprite_left: 0
  sprite_dalia: 1
